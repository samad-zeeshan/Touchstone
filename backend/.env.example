# Copy to .env for local dev, or set these as platform env vars in production.
# Everything here is optional: with no keys the app runs fully on the templated
# fallback (the "AI layer off" demonstration), graded by the same tested oracle.

# AI reword layer. Without this the prose stays templated and the toggle is a no-op.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Comma-separated browser origins allowed by CORS. Set to the deployed frontend URL.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional backend error reporting (Sentry free tier).
SENTRY_DSN=

# Optional narration audio via an OpenAI-compatible TTS endpoint.
TTS_API_KEY=
TTS_BASE_URL=https://api.openai.com/v1
TTS_MODEL=tts-1
TTS_VOICE=alloy
